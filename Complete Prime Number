class Solution(object):
    def completePrime(self, num):
        
        def isPrime(n):
            if n <= 1:
                return False
            for i in range(2, int(n**0.5) + 1):
                if n % i == 0:
                    return False
            return True
        
        s = str(num)
        n = len(s)
        
        # check prefixes
        for i in range(1, n + 1):
            if not isPrime(int(s[:i])):
                return False
        
        # check suffixes
        for i in range(n):
            if not isPrime(int(s[i:])):
                return False
        
        return True
