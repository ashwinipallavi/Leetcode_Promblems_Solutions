class Solution:
    def kConcatenationMaxSum(self, arr, k):
        MOD = 10**9 + 7
        
        # Kadane algorithm
        def kadane(nums):
            max_sum = 0
            curr = 0
            
            for n in nums:
                curr = max(n, curr + n)
                max_sum = max(max_sum, curr)
            
            return max_sum
        
        total_sum = sum(arr)
        
        if k == 1:
            return kadane(arr) % MOD
        
        max_double = kadane(arr * 2)
        
        if total_sum > 0:
            return (max_double + (k - 2) * total_sum) % MOD
        else:
            return max_double % MOD
